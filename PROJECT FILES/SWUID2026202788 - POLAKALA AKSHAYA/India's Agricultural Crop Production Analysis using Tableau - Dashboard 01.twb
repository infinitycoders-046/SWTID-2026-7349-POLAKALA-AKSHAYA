      <aliases enabled='yes' />
      <column datatype='real' name='[Area]' role='measure' type='quantitative' />
      <column caption='True Total Yield' datatype='real' name='[Calculation_0832341639061504]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Production]) / SUM([Area])' />
      </column>
      <column caption='Agricultural Yield' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1185009700392961]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Production]) / SUM([Area])' />
      </column>
      <column caption='Unit Type' datatype='string' name='[Calculation_1705078843166720]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Crop] = &apos;Cotton&apos; THEN &apos;Bales&apos;&#13;&#10;ELSEIF [Crop] = &apos;Coconut&apos; THEN &apos;Thousand Nuts&apos;&#13;&#10;ELSEIF [Crop] = &apos;Jute&apos; OR [Crop] = &apos;Mesta&apos; THEN &apos;Bales&apos;&#13;&#10;ELSE &apos;Metric Tonnes&apos;&#13;&#10;END' />
      </column>
      <column caption='zero' datatype='integer' name='[Calculation_2006619862142996]' role='measure' type='quantitative'>
