  <worksheets>
    <worksheet name='Crop-wise Total Production Analysis'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1'>Crop-wise Total Production Analysis</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (India’s Agricultural Crop Production Analysis(1997-2021))' name='federated.0lh5kly1tjht641ah031b1k3gn3z' />
          </datasources>
          <datasource-dependencies datasource='federated.0lh5kly1tjht641ah031b1k3gn3z'>
            <column datatype='string' name='[Crop]' role='dimension' type='nominal' />
            <column datatype='real' name='[Production]' role='measure' type='quantitative' />
            <column-instance column='[Crop]' derivation='None' name='[none:Crop:nk]' pivot='key' type='nominal' />
            <column-instance column='[Production]' derivation='Sum' name='[sum:Production:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0lh5kly1tjht641ah031b1k3gn3z].[none:Crop:nk]'>
            <groupfilter count='25' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([Production])' function='order' user:ui-marker='order'>
                <groupfilter function='level-members' level='[none:Crop:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
              </groupfilter>
            </groupfilter>
          </filter>
          <natural-sort column='[federated.0lh5kly1tjht641ah031b1k3gn3z].[none:Crop:nk]' direction='DESC' />
          <slices>
            <column>[federated.0lh5kly1tjht641ah031b1k3gn3z].[none:Crop:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <format attr='title' class='0' field='[federated.0lh5kly1tjht641ah031b1k3gn3z].[sum:Production:qk]' scope='cols' value='Total Production' />
          </style-rule>
          <style-rule element='cell'>
            <format attr='text-format' field='[federated.0lh5kly1tjht641ah031b1k3gn3z].[sum:Production:qk]' value='n#,##0,,.00M;-#,##0,,.00M' />
          </style-rule>
          <style-rule element='table'>
            <format attr='background-color' value='#f6eee3' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <color column='[federated.0lh5kly1tjht641ah031b1k3gn3z].[none:Crop:nk]' />
              <text column='[federated.0lh5kly1tjht641ah031b1k3gn3z].[sum:Production:qk]' />
